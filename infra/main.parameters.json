{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=japaneast}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "principalType": {
      "value": "${AZURE_PRINCIPAL_TYPE=User}"
    },
    "enableObservability": {
      "value": "${ENABLE_OBSERVABILITY=true}"
    },
    "environmentPurpose": {
      "value": "${ENVIRONMENT_PURPOSE=}"
    },
    "environmentLifecycle": {
      "value": "${ENVIRONMENT_LIFECYCLE=}"
    },
    "environmentWorkstream": {
      "value": "${ENVIRONMENT_WORKSTREAM=}"
    },
    "foundryGuideFeedbackPrincipalId": {
      "value": "${FOUNDRY_GUIDE_FEEDBACK_PRINCIPAL_ID=}"
    },
    "enableFoundryGuideWebApp": {
      "value": "${ENABLE_FOUNDRY_GUIDE_WEB_APP=false}"
    },
    "foundryGuideAgentName": {
      "value": "${FOUNDRY_GUIDE_AGENT_NAME=foundry-guide}"
    },
    "foundryGuideWebAuthClientId": {
      "value": "${FOUNDRY_GUIDE_WEB_AUTH_CLIENT_ID=}"
    },
    "foundryGuideWebAppServiceSku": {
      "value": "${FOUNDRY_GUIDE_WEB_APP_SERVICE_SKU=B1}"
    },
    "enableFoundryIq": {
      "value": "${ENABLE_FOUNDRY_IQ=false}"
    },
    "enableTokenUsageSample": {
      "value": "${ENABLE_TOKEN_USAGE_SAMPLE=false}"
    },
    "tokenUsagePublisherEmail": {
      "value": "${TOKEN_USAGE_PUBLISHER_EMAIL=noreply@contoso.com}"
    },
    "simpleTokenQuota": {
      "value": "${SIMPLE_TOKEN_QUOTA=600}"
    },
    "strictTokenQuota": {
      "value": "${STRICT_TOKEN_QUOTA=600}"
    },
    "strictReservationTokens": {
      "value": "${STRICT_RESERVATION_TOKENS=256}"
    },
    "strictMaxOutputTokens": {
      "value": "${STRICT_MAX_OUTPUT_TOKENS=64}"
    },
    "strictSafetyPaddingTokens": {
      "value": "${STRICT_SAFETY_PADDING_TOKENS=64}"
    }
  }
}
